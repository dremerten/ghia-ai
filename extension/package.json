{
  "name": "pyaid",
  "displayName": "PyAid",
  "version": "1.0.0",
  "description": "AI-powered Python guidance at your fingertips",
  "publisher": "andremerten",
  "license": "MIT",
  "engines": {
    "node": "24.14.0",
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andremerten/pyaid.git"
  },
  "bugs": {
    "url": "https://github.com/andremerten/pyaid/issues"
  },
  "homepage": "https://github.com/andremerten/pyaid#readme",
  "icon": "media/pyaid.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package",
    "validate": "node validate.js"
  },
  "dependencies": {
    "@pyaid/shared": "file:../shared",
    "ai": "^6.0.116",
    "undici": "^7.24.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "pyaid.explainCode",
        "title": "pyaid: Explain Selected Code"
      },
      {
        "command": "pyaid.writeToFile",
        "title": "pyaid: Write To File",
        "category": "pyaid"
      },
      {
        "command": "pyaid.retryHoverExplanation",
        "title": "pyaid: Retry Hover Explanation"
      },
      {
        "command": "pyaid.statusBarClick",
        "title": "pyaid: Show Menu"
      },
      {
        "command": "pyaid.openPanel",
        "title": "pyaid: Open Side Panel"
      },
      {
        "command": "pyaid.prototype.selectMode",
        "title": "pyaid: Select UI Mode"
      },
      {
        "command": "pyaid.quickPeek",
        "title": "pyaid: Quick Peek Explanation"
      },
      {
        "command": "pyaid.inlinePeek",
        "title": "pyaid: Inline Peek Explanation"
      },
      {
        "command": "pyaid.explainInPanel",
        "title": "pyaid: Explain in Side Panel"
      },
      {
        "command": "pyaid.explainFloating",
        "title": "pyaid: Explain in Floating Panel"
      },
      {
        "command": "pyaid.openWidePanel",
        "title": "pyaid: Open Wide Panel"
      },
      {
        "command": "pyaid.experiment.menu",
        "title": "pyaid: Hover Experiments Menu"
      },
      {
        "command": "pyaid.experiment.stop",
        "title": "pyaid: Stop Hover Experiment"
      },
      {
        "command": "pyaid.experiment.status",
        "title": "pyaid: Show Experiment Status"
      },
      {
        "command": "pyaid.experiment.run.null-returning",
        "title": "pyaid: Run Experiment - Null Returning"
      },
      {
        "command": "pyaid.experiment.run.always-return",
        "title": "pyaid: Run Experiment - Always Return Hover"
      },
      {
        "command": "pyaid.experiment.run.conditional",
        "title": "pyaid: Run Experiment - Conditional Hover"
      },
      {
        "command": "pyaid.experiment.run.multi-provider",
        "title": "pyaid: Run Experiment - Multi Provider"
      },
      {
        "command": "pyaid.experiment.run.registration-order-high-first",
        "title": "pyaid: Run Experiment - Registration Order (High First)"
      },
      {
        "command": "pyaid.experiment.run.registration-order-high-last",
        "title": "pyaid: Run Experiment - Registration Order (High Last)"
      },
      {
        "command": "pyaid.experiment.run.registration-order-first-second-high",
        "title": "pyaid: Run Experiment - Registration Order (Mixed)"
      },
      {
        "command": "pyaid.experiment.run.async",
        "title": "pyaid: Run Experiment - Async Provider"
      },
      {
        "command": "pyaid.experiment.run.undefined",
        "title": "pyaid: Run Experiment - Undefined Return"
      },
      {
        "command": "pyaid.experiment.run.empty-content",
        "title": "pyaid: Run Experiment - Empty Content"
      },
      {
        "command": "pyaid.askAI",
        "title": "pyaid: Ask Local Model"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "pyaid.explanationPanel",
          "name": "pyaid",
          "when": "pyaid.prototype.sidePanelEnabled"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pyaid.quickPeek",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      },
      {
        "command": "pyaid.explainInPanel",
        "key": "ctrl+shift+alt+e",
        "mac": "cmd+shift+alt+e",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "pyaid",
      "properties": {
        "pyaid.ollamaEndpoint": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama API endpoint URL."
        },
        "pyaid.model": {
          "type": "string",
          "default": "codegemma:2b",
          "description": "Model name to use for explanations."
        },
        "pyaid.askPythonMode": {
          "type": "boolean",
          "default": true,
          "description": "When true, free-form answers are tailored for Python developers with Python examples. Turn off to get general answers without Python code."
        },
        "pyaid.highlightColor": {
          "type": "string",
          "default": "",
          "description": "Background color for the hover-highlighted code block (e.g. \"rgba(0, 128, 128, 0.2)\"). Leave empty to use theme-aware defaults (dark: teal 15%, light: teal 25%, high-contrast: white 10%)."
        },
        "pyaid.enableExperiments": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental hover provider testing module. Only enable for development/testing purposes."
        },
        "pyaid.prototype.mode": {
          "type": "string",
          "enum": [
            "hover",
            "peek",
            "quickpeek",
            "inlinepeek",
            "sidepanel",
            "floatingpanel"
          ],
          "default": "hover",
          "enumDescriptions": [
            "Original hover tooltips (merged with VS Code hovers)",
            "Peek definition-style overlay using virtual documents",
            "Fast modal explanation using Quick Pick",
            "Inline decoration below the hovered line",
            "Persistent sidebar webview with history",
            "Floating webview panel beside the editor"
          ],
          "description": "UI mode for displaying AI explanations. Each mode offers different trade-offs."
        },
        "pyaid.prototype.sidePanelEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the pyaid panel in the Explorer sidebar."
        },
        "pyaid.prototype.enablePrototypes": {
          "type": "boolean",
          "default": true,
          "description": "Enable UI prototype alternatives (Peek View, Side Panel, Floating Panel). Set to false to disable alternative UI modes."
        }
      }
    }
  }
}